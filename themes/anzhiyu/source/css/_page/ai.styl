// ==========================================
// AI 中心页面样式 — 匹配 AnZhiYu 主题设计语言
// 参考: about.styl, equipment.styl, flink.styl
// ==========================================

// -------- 页面容器重置（参考 about 页面）--------
body[data-type='ai'] #page
  border: 0
  box-shadow: none !important
  padding: 0 !important
  background: transparent !important

body[data-type='ai'] #page .page-title
  display: none

body[data-type='ai'] #web_bg
  background: var(--anzhiyu-background)

// -------- AI 页面主容器 --------
#ai-page
  padding-top: 1rem

  // -------- 通用：author-content 布局（参考 about）--------
  .author-content
    display: flex
    flex-wrap: wrap
    justify-content: space-between
    width: 100%
    margin-top: 1rem

  // -------- 通用：author-content-item 卡片基类（参考 about）--------
  .author-content-item
    width: 49%
    border-radius: 24px
    background: var(--anzhiyu-card-bg)
    border: var(--style-border-always)
    box-shadow: var(--anzhiyu-shadow-border)
    position: relative
    padding: 1rem 2rem
    overflow: hidden

    +maxWidth768()
      width: 100% !important
      margin-top: 1rem
      padding: 1rem

  .author-content-item.single
    width: 100%

  // -------- 通用：card-content 遮罩层（参考 about）--------
  .author-content-item .card-content
    position: absolute
    width: 100%
    height: 100%
    top: 0
    left: 0
    z-index: 2
    display: flex
    flex-direction: column
    padding: 1rem 2rem

  .author-content-item .card-content .author-content-item-title
    margin-bottom: 0.5rem

  // -------- 通用：tips 小标签（参考 about）--------
  .author-content-item-tips
    opacity: 0.8
    font-size: 12px
    margin-bottom: 0.5rem

  // -------- 通用：title 大标题（参考 about）--------
  .author-content-item-title
    font-size: 36px
    font-weight: 700
    line-height: 1

  // -------- 通用：card-background-icon（参考 about buff 区域）--------
  .card-background-icon
    font-size: 12rem
    opacity: 0.2
    position: absolute
    right: 0
    bottom: -40%
    transform: rotate(30deg)
    transition: 2s ease-in-out

    i
      font-size: 12rem

// -------- Hero 头部卡片（参考 about .myInfoAndSayHello）--------
.ai-hero
  display: flex
  flex-direction: column
  justify-content: center
  color: var(--anzhiyu-white)
  background: linear-gradient(120deg, #425AEF 0, #818cf8 100%)
  background-size: 200%
  animation: gradient 15s ease infinite
  min-height: 240px

  +maxWidth768()
    min-height: 200px

  .author-content-item-tips
    color: rgba(255, 255, 255, 0.7)

  .author-content-item-title
    color: #fff
    margin-bottom: 0.25rem

  .ai-hero-desc
    opacity: 0.8
    font-size: 14px
    margin: 0.5rem 0 1.5rem
    color: rgba(255, 255, 255, 0.8)

  .ai-hero-stats
    display: flex
    gap: 1.5rem
    margin-top: auto

    +maxWidth768()
      gap: 1rem

  .ai-stat
    display: flex
    flex-direction: column
    background: rgba(255, 255, 255, 0.15)
    backdrop-filter: blur(10px)
    -webkit-backdrop-filter: blur(10px)
    border-radius: 12px
    padding: 0.5rem 1.25rem

    .ai-stat-num
      font-size: 28px
      font-weight: 700
      line-height: 1.2

    .ai-stat-label
      font-size: 12px
      opacity: 0.8

  &:hover .card-background-icon
    transform: rotate(20deg)

// -------- 分区标题（参考 equipment .goodthings-title）--------
.ai-section-label
  display: flex
  align-items: center
  gap: 0.5rem
  margin: 1.5rem 0 1rem
  font-size: 20px
  font-weight: 700
  color: var(--anzhiyu-fontcolor)
  line-height: 1

  i
    font-size: 22px
    color: var(--anzhiyu-main)

  .ai-section-desc
    margin-left: auto
    font-size: 12px
    font-weight: 400
    color: var(--anzhiyu-secondtext)

    +maxWidth768()
      display: none

// -------- AI 工具卡片 --------
.ai-tool-card
  width: 32% !important
  min-height: 200px
  cursor: pointer
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s
  display: flex
  flex-direction: row
  align-items: flex-start
  padding: 1.5rem !important
  gap: 1rem

  +maxWidth1200()
    width: 49% !important

  +maxWidth768()
    width: 100% !important
    min-height: auto

  &:hover:not(.disabled)
    border-color: var(--anzhiyu-main) !important
    box-shadow: var(--anzhiyu-shadow-main) !important
    transform: translateY(-2px)

  &.disabled
    opacity: 0.5
    cursor: not-allowed

  .ai-tool-icon
    width: 52px
    height: 52px
    min-width: 52px
    border-radius: 16px
    background: linear-gradient(135deg, var(--anzhiyu-main), #818cf8)
    display: flex
    align-items: center
    justify-content: center

    i
      font-size: 26px
      color: #fff

  .ai-tool-body
    flex: 1
    display: flex
    flex-direction: column
    min-width: 0

    .author-content-item-tips
      margin-bottom: 0.25rem
      color: var(--anzhiyu-main)
      font-weight: 500

    .author-content-item-title
      font-size: 18px !important
      margin-bottom: 0.35rem
      white-space: nowrap
      overflow: hidden
      text-overflow: ellipsis

    .ai-tool-desc
      font-size: 13px
      color: var(--anzhiyu-secondtext)
      line-height: 1.5
      display: -webkit-box
      overflow: hidden
      -webkit-line-clamp: 2
      -webkit-box-orient: vertical
      margin-bottom: 0.5rem

    .ai-tool-status
      margin-top: auto
      font-size: 12px
      color: var(--anzhiyu-secondtext)
      background: var(--anzhiyu-gray-op)
      padding: 3px 12px
      border-radius: 20px
      display: inline-block
      align-self: flex-start

    .ai-tool-action
      margin-top: auto
      display: flex
      align-items: center
      gap: 4px
      font-size: 13px
      color: var(--anzhiyu-main)
      font-weight: 500
      align-self: flex-start
      transition: gap 0.3s

      i
        font-size: 12px
        transition: transform 0.3s

  &:hover:not(.disabled) .ai-tool-action
    gap: 8px

    i
      transform: translateX(2px)

// -------- AI 作品卡片（参考 flink 卡片风格）--------
.ai-work-card
  width: 32% !important
  padding: 0 !important
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s

  +maxWidth1200()
    width: 49% !important

  +maxWidth768()
    width: 100% !important

  &:hover
    border-color: var(--anzhiyu-main) !important
    box-shadow: var(--anzhiyu-shadow-main) !important
    transform: translateY(-2px)

  .ai-work-cover
    width: 100%
    height: 200px
    overflow: hidden
    background: var(--anzhiyu-secondbg)

    img
      width: 100%
      height: 100%
      object-fit: cover
      transition: transform 0.6s ease-out

  &:hover .ai-work-cover img
    transform: scale(1.05)

  .ai-work-cover-empty
    display: flex
    align-items: center
    justify-content: center

    i
      font-size: 48px
      color: var(--anzhiyu-secondtext)
      opacity: 0.4

  .ai-work-body
    padding: 1rem 1.5rem 1.5rem

    .author-content-item-tips
      margin-bottom: 0.25rem
      color: var(--anzhiyu-main)
      font-weight: 500

    .author-content-item-title
      font-size: 18px !important
      margin-bottom: 0.25rem
      white-space: nowrap
      overflow: hidden
      text-overflow: ellipsis

    .ai-work-desc
      font-size: 13px
      color: var(--anzhiyu-secondtext)
      line-height: 1.5
      display: -webkit-box
      overflow: hidden
      -webkit-line-clamp: 2
      -webkit-box-orient: vertical
      margin-bottom: 0.75rem

    .ai-work-footer
      display: flex
      align-items: center
      justify-content: space-between

      .ai-work-date
        font-size: 12px
        color: var(--anzhiyu-secondtext)

      .ai-work-link
        font-size: 12px
        color: var(--anzhiyu-main)
        text-decoration: none
        font-weight: 500
        padding: 3px 10px
        border-radius: 20px
        background: var(--anzhiyu-gray-op)
        transition: background 0.3s, color 0.3s

        &:hover
          background: var(--anzhiyu-main)
          color: var(--anzhiyu-white)

// -------- 空状态 --------
.ai-empty
  text-align: center
  padding: 3rem 1rem
  color: var(--anzhiyu-secondtext)
  background: var(--anzhiyu-card-bg)
  border-radius: 24px
  border: var(--style-border-always)
  box-shadow: var(--anzhiyu-shadow-border)
  margin-top: 1rem

  i
    font-size: 48px
    margin-bottom: 0.5rem
    opacity: 0.3

  p
    font-size: 14px
    margin: 0

// ==========================================
// 工具交互面板（抽屉）—— 保留交互功能
// ==========================================

.ai-tool-panel
  position: fixed
  top: 0
  right: 0
  bottom: 0
  left: 0
  z-index: 100
  pointer-events: none
  visibility: hidden

  &.active
    pointer-events: auto
    visibility: visible

    .ai-tool-panel-overlay
      opacity: 1

    .ai-tool-panel-drawer
      transform: translateX(0)

.ai-tool-panel-overlay
  position: absolute
  inset: 0
  background: rgba(0, 0, 0, 0.4)
  backdrop-filter: blur(4px)
  -webkit-backdrop-filter: blur(4px)
  opacity: 0
  transition: opacity 0.35s ease

.ai-tool-panel-drawer
  position: absolute
  top: 0
  right: 0
  bottom: 0
  width: 55vw
  min-width: 420px
  max-width: 900px
  background: var(--anzhiyu-card-bg)
  box-shadow: -8px 0 40px rgba(0, 0, 0, 0.15)
  transform: translateX(100%)
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1)
  display: flex
  flex-direction: column

  +maxWidth768()
    width: 100vw
    min-width: unset
    max-width: unset

.ai-tool-panel-header
  display: flex
  align-items: center
  justify-content: space-between
  padding: 1rem 1.5rem
  border-bottom: var(--style-border)
  flex-shrink: 0

  .ai-tool-panel-title
    display: flex
    align-items: center
    gap: 0.5rem
    font-size: 1.1rem
    font-weight: 600
    color: var(--anzhiyu-fontcolor)

    i
      font-size: 1.3rem
      color: var(--anzhiyu-main)

.ai-panel-btn-close
  width: 36px
  height: 36px
  border-radius: 10px
  border: var(--style-border)
  background: var(--anzhiyu-card-bg)
  color: var(--anzhiyu-fontcolor)
  cursor: pointer
  display: flex
  align-items: center
  justify-content: center
  transition: background 0.3s, color 0.3s, border-color 0.3s

  &:hover
    background: #ef4444
    color: #fff
    border-color: #ef4444

  i
    font-size: 18px

.ai-tool-panel-body
  flex: 1
  overflow: hidden
  display: flex
  flex-direction: column

// -------- iframe 容器 --------
.ai-iframe-container
  width: 100%
  height: 100%
  display: flex
  flex-direction: column
  position: relative

.ai-iframe-loading
  position: absolute
  inset: 0
  display: flex
  flex-direction: column
  align-items: center
  justify-content: center
  gap: 0.75rem
  color: var(--anzhiyu-secondtext)
  background: var(--anzhiyu-card-bg)
  z-index: 2
  pointer-events: none

  i
    font-size: 32px
    color: var(--anzhiyu-main)

.ai-tool-panel-drawer iframe
  width: 100%
  height: 100%
  border: none
  background: #fff
  border-radius: 0

.anzhiyu-spin
  animation: anzhiyu-spin 1s linear infinite

@keyframes anzhiyu-spin
  from
    transform: rotate(0deg)
  to
    transform: rotate(360deg)

// -------- API 对话容器 --------
.ai-api-container
  width: 100%
  height: 100%
  display: flex
  flex-direction: column

.ai-chat-messages
  flex: 1
  overflow-y: auto
  padding: 1rem 1.5rem
  display: flex
  flex-direction: column
  gap: 1rem

  &::-webkit-scrollbar
    width: 4px

  &::-webkit-scrollbar-thumb
    background: var(--anzhiyu-secondtext)
    border-radius: 2px
    opacity: 0.3

// 聊天气泡（参考主题 style-border + card-bg）
.ai-message
  display: flex
  gap: 0.75rem
  max-width: 85%
  animation: slide-in 0.3s ease backwards

  .ai-message-avatar
    width: 36px
    height: 36px
    border-radius: 10px
    display: flex
    align-items: center
    justify-content: center
    flex-shrink: 0

    i
      font-size: 18px

  .ai-message-content
    padding: 0.75rem 1rem
    line-height: 1.6
    font-size: 0.9rem
    word-break: break-word
    border-radius: 16px

    p
      margin: 0.25rem 0
      &:first-child
        margin-top: 0
      &:last-child
        margin-bottom: 0

    pre
      background: rgba(0, 0, 0, 0.06)
      padding: 0.75rem
      border-radius: 8px
      overflow-x: auto
      font-size: 0.8rem
      margin: 0.5rem 0

      code
        background: none
        padding: 0

    code
      background: rgba(0, 0, 0, 0.06)
      padding: 2px 6px
      border-radius: 4px
      font-size: 0.85em

  &.ai-message-user
    align-self: flex-end
    flex-direction: row-reverse

    .ai-message-avatar
      background: var(--anzhiyu-main)
      i
        color: #fff

    .ai-message-content
      background: var(--anzhiyu-main)
      color: #fff
      border-radius: 16px 4px 16px 16px

  &.ai-message-system,
  &.ai-message-assistant
    align-self: flex-start

    .ai-message-avatar
      background: linear-gradient(135deg, var(--anzhiyu-main), #818cf8)
      i
        color: #fff

    .ai-message-content
      background: var(--anzhiyu-secondbg)
      color: var(--anzhiyu-fontcolor)
      border-radius: 4px 16px 16px 16px

  &.ai-message-error .ai-message-content
    background: rgba(239, 68, 68, 0.08)
    color: #ef4444
    border: 1px solid rgba(239, 68, 68, 0.2)

// 输入区域
.ai-chat-input-area
  padding: 1rem 1.5rem
  border-top: var(--style-border)
  flex-shrink: 0

.ai-chat-input-row
  display: flex
  gap: 0.5rem
  align-items: flex-end

textarea.ai-chat-input
  flex: 1
  resize: none
  border: var(--style-border)
  border-radius: 12px
  padding: 0.75rem 1rem
  font-size: 0.9rem
  font-family: inherit
  line-height: 1.5
  background: var(--anzhiyu-secondbg)
  color: var(--anzhiyu-fontcolor)
  outline: none
  transition: border-color 0.3s
  max-height: 120px

  &:focus
    border-color: var(--anzhiyu-main)

  &::placeholder
    color: var(--anzhiyu-secondtext)

.ai-chat-send-btn
  width: 44px
  height: 44px
  border-radius: 12px
  border: none
  background: var(--anzhiyu-main)
  color: #fff
  cursor: pointer
  display: flex
  align-items: center
  justify-content: center
  flex-shrink: 0
  transition: opacity 0.3s, transform 0.3s

  &:hover
    opacity: 0.85
    transform: scale(1.05)

  &:active
    transform: scale(0.95)

  &:disabled
    opacity: 0.5
    cursor: not-allowed
    transform: none

  i
    font-size: 18px

.ai-chat-status
  display: flex
  align-items: center
  justify-content: space-between
  margin-top: 0.5rem
  min-height: 1.2rem

  #ai-chat-status-text
    font-size: 12px
    color: var(--anzhiyu-secondtext)

  #ai-token-usage
    font-size: 11px
    color: var(--anzhiyu-secondtext)
    padding: 2px 8px
    background: var(--anzhiyu-secondbg)
    border-radius: 12px
    border: var(--style-border)

// -------- 暗色模式适配 --------
[data-theme='dark']
  .ai-tool-panel-drawer
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.5)

  .ai-tool-panel-drawer iframe
    background: #1a1a2e

  .ai-message
    &.ai-message-system .ai-message-content,
    &.ai-message-assistant .ai-message-content
      pre, code
        background: rgba(255, 255, 255, 0.06)

  .ai-hero
    .ai-stat
      background: rgba(255, 255, 255, 0.1)
