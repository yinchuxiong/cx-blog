      "id": "execute-bilibili",
      "name": "Execute: 获取B站视频"
    },
    {
      "parameters": {
        "jsCode": "// 解析 Execute Command 的 stdout（JSON 数组字符串）\nconst raw = $input.first().json;\n\nlet data;\nconst stdout = raw.stdout;\nif (typeof stdout === 'string' && stdout.trim().length > 0) {\n  try {\n    data = JSON.parse(stdout);\n  } catch (e) {\n    console.error('JSON parse error:', e.message);\n    return [];\n  }\n} else if (Array.isArray(raw)) {\n  data = raw;\n} else {\n  return [];\n}\n\nif (!Array.isArray(data) || data.length === 0) {\n  console.log('没有新视频');\n  return [];\n}\n\n// 只保留有字幕的视频\nconst withSubs = data.filter(v => v[\"有字幕\"] === true);\n\nif (withSubs.length === 0) {\n  console.log('没有带字幕的新视频');\n  return [];\n}\n\nconsole.log(`获取到 ${withSubs.length} 条带字幕的新视频`);\n\n// 拆成 n8n 逐条 item\nreturn withSubs.map(item => ({ json: item }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1280, 400],
      "id": "code-split-filter",
      "name": "Code: 拆分 & 过滤字幕"
    },
    {
      "parameters": {
        "model": "deepseek-v4-pro",
