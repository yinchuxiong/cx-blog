    {
      "parameters": {
        "resource": "bitable",
        "operation": "bitable:table:record:add",
        "app_toke": "BlAiwkRq1iBcTYkE7hScyJ3Ynwg",
        "table_id": "tblLiGKKRM2XOM3L",
        "body": "={\"fields\":{\n  \"标题\":\"{{ $json['标题'] }}\",\n  \"内容\":\"{{ $json['内容'] }}\",\n  \"日期\":\"{{ $json['日期'] }}\",\n  \"链接\": {\n    \"text\": \"视频链接\",\n    \"link\": \"{{ $json['链接'].replace(/\\n/g, '') }}\"\n  },\n  \"来源\":\"{{ $json['来源'] }}\",\n  \"板块\":\"{{ $json['板块'] }}\"\n}}"
      },
      "type": "n8n-nodes-feishu-lite.feishuNode",
      "typeVersion": 1,
      "position": [80, 400],
      "id": "feishu-bitable",
      "name": "Feishu: 写入多维表格",
      "credentials": {
        "feishuCredentialsApi": {
          "id": "A45UlAVxbXmsWakm",
          "name": "Feishu account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 把所有摘要合并成一篇日报推送\nconst items = $input.all();\n\nif (items.length === 0) {\n  return [{ json: { markdown: \"## 今天没有新的B站视频更新 🎬\" } }];\n}\n\nconst today = new Date().toISOString().slice(0, 10);\nlet md = `# ${today} B站 AI/开源 日报\\n\\n`;\n\n// 按来源分组\nconst groups = {};\nfor (const item of items) {\n  const source = item.json[\"来源\"] || \"B站\";\n  if (!groups[source]) groups[source] = [];\n  groups[source].push(item.json);\n}\n\nfor (const [source, entries] of Object.entries(groups)) {\n  md += `## ${source}\\n\\n`;\n  for (const e of entries) {\n    md += `**${e[\"标题\"]}**\\n`;\n    md += `${e[\"内容\"] || \"\"}\\n`;\n    md += `📺 ${e[\"链接\"] || \"\"}\\n\\n`;\n  }\n  md += \"---\\n\";\n}\n\nreturn [{ json: { markdown: md.trim() } }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [80, 640],
      "id": "code-daily-report",
      "name": "Code: 日报拼接"
    },
    {
      "parameters": {
        "jsCode": "const markdown = $input.first().json.markdown;\n\nreturn [\n  {\n    json: {\n      msg_type: \"interactive\",\n      card: {\n        elements: [\n          {\n            tag: \"markdown\",\n            content: markdown\n          }\n        ]\n      }\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 640],
